{
	"group/launchers": {
		"orientation": "horizontal",
		"modules": [
			"custom/chromium",
			"custom/terminal",
			"custom/discord",
			"custom/steam",
			"custom/vpn",
			"custom/blueman",
			"custom/neovim"
		]
	},

	"custom/chromium": {
		"format": "",
