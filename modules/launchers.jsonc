		"tooltip": false
	},

	"custom/terminal": {
		"format": "",
		"on-click": "foot",
		"tooltip": false
	},

	"custom/discord": {
		"format": "",
		"on-click": "discord",
		"tooltip": false
	},

	
	"custom/vpn": {
		"format": "",
