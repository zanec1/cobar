{
	"reload_style_on_change": true,
	"include": [
		"~/.config/waybar/modules/*.jsonc"
	],

	"modules-left": [
		"hyprland/workspaces",
		"hyprland/window"
	],
	"modules-center": [
	],
	"modules-right": [
		"tray",
		"cpu",
		"memory",
		"network",
		"pulseaudio",
		"backlight",
		"power-profiles-daemon",
		"battery",
		"clock"
	]
}
