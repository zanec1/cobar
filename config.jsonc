{
	"reload_style_on_change": true,
	"position": "bottom",
	"include": [
		"~/.config/waybar/modules/*.jsonc"
	],

	"modules-left": [
		"sway/workspaces",
		"sway/mode",
        "sway/window"
	],
	"modules-center": [
	],
	"modules-right": [
		"tray",
		"network",
		"pulseaudio",
		"backlight",
		"battery",
		"clock"
	]
}
