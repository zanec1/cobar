{
	"reload_style_on_change": true,
	"position": "bottom",
	"include": [
		"~/.config/waybar/modules/*.jsonc"
	],

	"modules-left": [
		"clock",
		"sway/mode",
        "sway/window"
	],
	"modules-center": [
		"sway/workspaces",
	],
	"modules-right": [
		"tray",
        "cpu",
        "memory",
		"network",
		"pulseaudio",
		"backlight",
        "power-profiles-daemon",
		"battery",
        "user"
	]
}
