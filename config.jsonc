{
	"reload_style_on_change": true,
	"position": "bottom",

	"include": [
		"~/.config/waybar/modules/*.jsonc"
	],

	"modules-left": [
		"hyprland/workspaces",
		"hyprland/window"
	],
	"modules-center": [
		"group/launchers"
	],
	"modules-right": [
		"tray",
		// "cpu",
		// "memory",
		"network",
		"pulseaudio",
		"backlight",
		"power-profiles-daemon",
		"battery",
		"clock"
	]
}
